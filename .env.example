# Copy this file to `.env` and replace placeholder values.
# `.env` is gitignored — never commit real credentials.

# === Postgres / TimescaleDB (consumed by docker-compose.yml) ===
POSTGRES_USER=qfb
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=quantflowbots

# === Frontend (Vite — picked up by import.meta.env on dev server) ===
VITE_API_URL=http://localhost:5087
VITE_HUB_URL=http://localhost:5087/hubs/market

# === Backend secrets ===
# Put real values in `appsettings.Development.json` (gitignored) for local dev,
# OR set as environment variables (ASP.NET binds these automatically):
#
#   ConnectionStrings__Default = Host=127.0.0.1;Port=5433;Database=quantflowbots;Username=qfb;Password=<same as POSTGRES_PASSWORD above>
#   ConnectionStrings__Redis   = 127.0.0.1:6379
#
# Production keys belong in `dotnet user-secrets` (per-machine, never in repo):
#   dotnet user-secrets set "Security:EncryptionKey" "<32+ random chars>"
#   dotnet user-secrets set "Jwt:SigningKey"        "<32+ random chars, identical in API + Worker projects>"
